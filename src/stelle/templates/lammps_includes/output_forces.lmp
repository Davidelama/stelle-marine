#---Output of forces--------------------------------------------#

variable vx  atom x
variable vy  atom y
variable vfx atom f_save_forces[1]
variable vfy atom f_save_forces[2]

compute molchunk stars chunk/atom molecule

fix coreout cores ave/chunk ${dumptime_angle} 1 ${dumptime_angle} molchunk v_vx v_vy v_theta v_vfx v_vfy append ${name}_cores.dat